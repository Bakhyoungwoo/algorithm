#include <iostream>
#include <string>
#include <ctime>
using namespace std;

int main() {
    string date_string;
    cin >> date_string;

    // 입력받은 기준 날짜를 파싱하여 각각의 구성 요소로 나눕니다.
    tm tm_base = {};
    strptime(date_string.c_str(), "%Y-%m-%d", &tm_base);

    int base_year = tm_base.tm_year + 1900;
    int base_month = tm_base.tm_mon + 1;
    int base_day = tm_base.tm_mday;

    int number;
    cin >> number;

    int count = 0;

    for (int i = 0; i < number; i++) {
        // 새로운 날짜를 입력받아 파싱합니다.
        cin >> date_string;
        tm tm_other = {};
        strptime(date_string.c_str(), "%Y-%m-%d", &tm_other);

        int ot_year = tm_other.tm_year + 1900;
        int ot_month = tm_other.tm_mon + 1;
        int ot_day = tm_other.tm_mday;

        // 비교하여 count를 증가시킵니다.
        if (ot_year > base_year || (ot_year == base_year && ot_month > base_month) || (ot_year == base_year && ot_month == base_month && ot_day > base_day)) {
            count++;
        }
        else if(ot_year == base_year && ot_month == base_month && ot_day == base_day)
        {
            count++;
        }
    }

    // 결과 출력
    cout << count;

    return 0;
}
